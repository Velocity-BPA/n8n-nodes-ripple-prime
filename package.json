{
  "name": "@velocity-bpa/n8n-nodes-ripple-prime",
  "version": "1.0.0",
  "description": "n8n community node for Ripple Prime institutional trading platform",
  "license": "bsl-catalog",
  "homepage": "https://docs.n8n.io/integrations/community-nodes/",
  "author": {
    "name": "Velocity BPA",
    "email": "engineering@velocitybpa.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/velocity-bpa/n8n-nodes-ripple-prime.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@9.1.4",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist/**/*"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/RipplePrimeApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/RipplePrime/RipplePrime.node.js"
    ]
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.15.1",
    "@typescript-eslint/parser": "^7.15.1",
    "@types/node": "^18.16.16",
    "eslint": "^8.56.0",
    "gulp": "^4.0.2",
    "n8n-workflow": "*",
    "prettier": "^3.0.0",
    "typescript": "^5.1.6"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "dependencies": {
    "axios": "^1.6.0"
  }
}